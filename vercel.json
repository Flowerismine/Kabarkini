{
  "crons": [
    {
      "path": "/api/workflow/run-morning",
      "schedule": "30 23 * * *"
    },
    {
      "path": "/api/workflow/run-noon",
      "schedule": "0 5 * * *"
    },
    {
      "path": "/api/workflow/run-evening",
      "schedule": "0 11 * * *"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=()"
        }
      ]
    }
  ]
}
